{
  "functions": {
    "api/search.js": {
      "memory": 256,
      "maxDuration": 15
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "https://savvey.app"
        },
        {
          "key": "Vary",
          "value": "Origin"
        }
      ]
    }
  ]
}
