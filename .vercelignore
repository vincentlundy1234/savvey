# Savvey .vercelignore — files NOT shipped to the production Vercel deploy.
# Refreshed Wave V.38 (8 May 2026) — stripped 12 stale dead-file references
# pointing at things removed during the v2 -> v3.0 Smart Router pivot.

# Generic backup / archive patterns (forward-looking — no current matches)
_archive/
*.archive
*.backup-*
*.recovered

# Cowork sandbox staging artefacts (also in .gitignore so unlikely to reach
# Vercel, but defence in depth)
_wave_*/
_staging_*/
APPLY*.ps1
COMMIT_MSG.txt
*.new

# Internal-only tools (run locally; not part of production runtime)
tools/
.github/

# Local-only env files (never commit, but defence in depth)
.env
.env.local

# OS / editor noise (also in .gitignore)
.DS_Store
Thumbs.db
.vscode/
.idea/

# Capacitor wrapper artefacts (built locally for spike branch — never
# shipped to web Vercel deploy)
android/
ios/
